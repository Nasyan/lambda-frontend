BACKEND_INTERNAL_URL=http://localhost:8000

# APP_MODE can live in the shared ../.env, but browser-visible frontend values
# must be exposed with NEXT_PUBLIC_* in .env.local or next.config.
# NEXT_PUBLIC_APP_MODE=local

# NEXT_PUBLIC_API_URL is still accepted by next.config.ts as a fallback for
# older local setups, but browser API calls are now same-origin relative paths.
# NEXT_PUBLIC_API_URL=http://localhost:8000
